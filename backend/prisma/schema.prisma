generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id String @id @default(cuid())

  customerCode String @unique

  fullName String

  companyName String?

  phone String @unique

  alternatePhone String?

  email String?

  address String?

  panVat String?

  notes String?

  repairJobs RepairJob[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

enum JobStatus {
  RECEIVED
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  READY
  DELIVERED
  CANCELLED
}

enum InventoryType {
  PRODUCT
  SPARE_PART
  CONSUMABLE
}

model RepairJob {
  id String @id @default(cuid())

  jobNumber String @unique

  customerId   String
  technicianId String?

  customer   Customer    @relation(fields: [customerId], references: [id])
  technician Technician? @relation(fields: [technicianId], references: [id])

  brand String
  model String

  serialNumber String?

  processor String?
  ram       String?
  storage   String?

  color String?

  charger Boolean @default(false)
  bag     Boolean @default(false)

  complaint String

  diagnosis String?

  estimate Float?

  advance Float @default(0)

  totalAmount Float?

  dueAmount Float?

  status JobStatus @default(RECEIVED)

  receivedDate DateTime @default(now())

  deliveryDate DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Technician {
  id String @id @default(cuid())

  name String

  phone String? @unique

  email String? @unique

  specialization String?

  status String @default("Active")

  repairJobs RepairJob[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Inventory {
  id String @id @default(cuid())

  itemCode String @unique

  itemName String

  itemType InventoryType

  category String

  brand String?

  model String?

  purchasePrice Float @default(0)

  sellingPrice Float @default(0)

  quantity Int @default(0)

  minimumStock Int @default(0)

  supplier String?

  location String?

  barcode String?

  unit String @default("PCS")

  description String?

  status String @default("Active")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
model Supplier {
  id String @id @default(cuid())

  supplierCode String @unique

  companyName String

  contactPerson String?

  phone String @unique

  alternatePhone String?

  email String?

  address String?

  panVat String?

  website String?

  notes String?

  status String @default("Active")

  purchases Purchase[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
model Purchase {
  id String @id @default(cuid())

  purchaseNumber String @unique

  supplierId String

  supplier Supplier @relation(fields: [supplierId], references: [id])

  purchaseDate DateTime @default(now())

  totalAmount Float

  discount Float @default(0)

  tax Float @default(0)

  paidAmount Float @default(0)

  dueAmount Float

  paymentMethod String?

  invoiceNumber String?

  remarks String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
