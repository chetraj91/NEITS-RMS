generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id         String      @id @default(cuid())
  fullName   String
  phone      String      @unique
  email      String?
  address    String?
  createdAt  DateTime    @default(now())

  jobs RepairJob[]
}

model Technician {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?

  jobs RepairJob[]
}

model RepairJob {
  id              String   @id @default(cuid())
  jobNumber       Int      @unique @default(autoincrement())

  customerId      String
  technicianId    String?

  deviceBrand     String
  deviceModel     String
  serialNumber    String?

  problem         String
  diagnosis       String?

  estimateAmount  Float?
  repairCost      Float?

  status          String   @default("Received")

  paymentStatus   String   @default("Pending")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer @relation(fields:[customerId], references:[id])
  technician Technician? @relation(fields:[technicianId], references:[id])
}
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}