generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id String @id @default(cuid())

  customerCode String @unique

  fullName String

  companyName String?

  phone String @unique

  alternatePhone String?

  email String?

  address String?

  panVat String?

  notes String?

  repairJobs RepairJob[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

enum JobStatus {
  RECEIVED
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  READY
  DELIVERED
  CANCELLED
}

model RepairJob {
  id String @id @default(cuid())

  jobNumber String @unique

  customerId   String
  technicianId String?

  customer   Customer    @relation(fields: [customerId], references: [id])
  technician Technician? @relation(fields: [technicianId], references: [id])

  brand String
  model String

  serialNumber String?

  processor String?
  ram       String?
  storage   String?

  color String?

  charger Boolean @default(false)
  bag     Boolean @default(false)

  complaint String

  diagnosis String?

  estimate Float?

  advance Float @default(0)

  totalAmount Float?

  dueAmount Float?

  status JobStatus @default(RECEIVED)

  receivedDate DateTime @default(now())

  deliveryDate DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Technician {
  id String @id @default(cuid())

  name String

  phone String? @unique

  email String? @unique

  specialization String?

  status String @default("Active")

  repairJobs RepairJob[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
